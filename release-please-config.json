{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "bootstrap-sha": "c2b2b58ebbe1bd1a41cbacc92efa17728c731566",
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release",
  "plugins": ["cargo-workspace"],
  "packages": {
    "crates/uroborosql-fmt": {
      "package-name": "uroborosql-fmt",
      "component": "uroborosql-fmt",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "crates/uroborosql-fmt-cli": {
      "package-name": "uroborosql-fmt-cli",
      "component": "uroborosql-fmt-cli",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "crates/uroborosql-fmt-napi": {
      "package-name": "uroborosql-fmt-napi",
      "component": "uroborosql-fmt-napi",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "/crates/uroborosql-fmt-napi/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/crates/uroborosql-fmt-napi/npm/darwin-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/crates/uroborosql-fmt-napi/npm/linux-x64-gnu/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/crates/uroborosql-fmt-napi/npm/win32-x64-msvc/package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "crates/uroborosql-fmt-wasm": {
      "package-name": "uroborosql-fmt-wasm",
      "component": "uroborosql-fmt-wasm",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "crates/uroborosql-lint": {
      "package-name": "uroborosql-lint",
      "component": "uroborosql-lint",
      "include-component-in-tag": true,
      "release-as": "0.1.0",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/uroborosql-lint-cli": {
      "package-name": "uroborosql-lint-cli",
      "component": "uroborosql-lint-cli",
      "include-component-in-tag": true,
      "release-as": "0.1.0",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/uroborosql-language-server": {
      "package-name": "uroborosql-language-server",
      "component": "uroborosql-language-server",
      "include-component-in-tag": true,
      "release-as": "1.0.0",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
